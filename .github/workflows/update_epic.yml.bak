name: "🎮 • Auto-Update Epic Games Apps in apps.json"

on:
  schedule:
    - cron: '0 0 * * *'
  workflow_dispatch:

jobs:
  update-epic:
    runs-on: ubuntu-latest
    permissions:
      contents: write

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.x'

      - name: Fetch and update apps
        run: python .github/scripts/update_epic.py

      - name: Commit and push changes
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          git add apps.json epic-ver.txt
          git commit -m "chore: Update Fortnite and Fall Guys to latest version" || exit 0
          git push